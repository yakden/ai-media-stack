# Copy to .env and adjust. All values have sensible defaults (see app/config.py).

# ============================ HTTP server ============================
HOST=0.0.0.0
PORT=8120

# ============================ Auth / SSO =============================
# This service sits behind the nginx cookie-SSO gateway, which injects the
# authenticated user via a trusted header. auth.py treats the presence of this
# header as authenticated. Must match the proxy_set_header in the nginx vhost.
SSO_HEADER=X-Email

# Optional bearer token for SSH-tunnel / CLI access that bypasses the SSO proxy.
# If set, requests may instead send: Authorization: Bearer <API_KEY>
# API_KEY=change-me

# ============================ Storage paths ==========================
# Container paths (bind-mounted from ./data and ./models). Defaults are fine.
DATA_DIR=/app/data
MODELS_DIR=/app/models
# Subdirs under DATA_DIR (relative paths stored in the DB are resolved here):
#   recordings/<camera_id>/<event_id>.mp4
#   thumbnails/<event_id>.jpg
#   faces/<person_id>/<file>.jpg
#   segments/<camera_id>/seg_*.mp4
DB_PATH=/app/data/vms.db

# ============================ Detection ==============================
# Backend: onnx (default, YOLOv8n via onnxruntime) | cpu (force ONNX on CPU) |
#          deepstream (optional high-throughput backend, see compose override).
DETECTOR_BACKEND=onnx
# Device for the ONNX backend: cuda (default) | cpu.
# Set to cpu (or DETECTOR_BACKEND=cpu) to keep running under GPU eviction.
DETECTOR_DEVICE=cuda
YOLO_MODEL_PATH=/app/models/yolov8n.onnx
# fp16 inference (T4 supports it). Set false to run fp32.
DETECTOR_FP16=true
# Person-detection confidence threshold (per-camera value overrides this).
DETECT_CONF=0.4
# Only the COCO 'person' class (id 0) is acted on in the MVP.
DETECT_CLASSES=0
# Worker frame-processing rate (detection FPS, not stream FPS). Keeps GPU light.
DETECT_FPS=5

# Optional DeepStream metadata endpoint (only when DETECTOR_BACKEND=deepstream;
# normally set by docker-compose.deepstream.yml).
# DEEPSTREAM_URL=http://deepstream:8121

# ============================ Recording =============================
# Rolling segment length (seconds) for the warm ffmpeg pre-roll buffer.
SEGMENT_SECONDS=2
# Pre/post-roll around a person trigger (per-camera values override these).
PRE_SECONDS=5
POST_SECONDS=10
# Debounce: seconds a person must be absent before a new event can trigger.
TRIGGER_COOLDOWN=15

# ============================ Face recognition =======================
# insightface model pack (SCRFD detector + ArcFace r50 -> 512-d embedding).
FACE_MODEL_PACK=buffalo_l
# Run faces under onnxruntime on: cuda (default) | cpu.
FACE_DEVICE=cuda
# Cosine-similarity threshold for a positive identity match (normalized embeds).
FACE_MATCH_THRESHOLD=0.45
# Minimum face detector score to attempt recognition.
FACE_DET_THRESHOLD=0.5

# ============================ Misc ==================================
LOG_LEVEL=INFO
